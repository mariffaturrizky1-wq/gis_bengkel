#--------------------------------------------------------------------
# ENVIRONMENT (development atau production)
#--------------------------------------------------------------------
CI_ENVIRONMENT = development

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------
app.baseURL = 'http://localhost/gis_bengkel/public/'

# Jika menggunakan virtual host seperti gis_bengkel.test, ganti di atas.
app.forceGlobalSecureRequests = false

#--------------------------------------------------------------------
# DATABASE
#--------------------------------------------------------------------
database.default.hostname = localhost
database.default.database = gis_bengkel
database.default.username = root
database.default.password = 
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port = 3306

#--------------------------------------------------------------------
# ENCRYPTION KEY (Wajib diisi untuk session/security)
#--------------------------------------------------------------------
# Anda bisa membuatnya via terminal: php spark key:generate
encryption.key = 